{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/licenses/layout,_N_T_/licenses/page,_N_T_/licenses"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/licenses/__PAGE__",
    "/licenses",
    "/_index",
    "/_head"
  ]
}